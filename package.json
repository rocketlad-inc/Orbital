{
  "name": "orbital-frontend",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "ajv": "^8.20.0",
    "http-proxy-middleware": "^2.0.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "typescript": "^4.9.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "node scripts/bundle-migrations.js && react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "worker:dev": "wrangler dev",
    "db:migrate:local": "wrangler d1 migrations apply orbital --local",
    "db:migrate:remote": "wrangler d1 migrations apply orbital"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0"
  }
}
